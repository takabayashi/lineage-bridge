# ── LineageBridge Terraform Variables ─────────────────────────────────────────
#
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# Estimated monthly cost for this setup: ~$50-80/month
#   - Databricks workspace:    ~$0 (pay per compute usage only)
#   - Databricks compute:      ~$20-40/month (if running clusters)
#   - Confluent Cloud basic:   ~$25-30/month (basic cluster + Schema Registry)
#   - AWS S3 storage:          ~$1-2/month
#   - AWS IAM:                 free
#
# Tip: destroy resources when not in use to minimise costs:
#   make infra-destroy
# ─────────────────────────────────────────────────────────────────────────────

# AWS region — must match the region you want for both Databricks and Confluent
aws_region = "us-east-1"

# Environment tag applied to all resources
environment = "dev"

# Project name used for resource naming and tagging
project_name = "lineage-bridge"

# Databricks account ID — find it in the Databricks Account Console
# https://accounts.cloud.databricks.com
databricks_account_id = "YOUR_DATABRICKS_ACCOUNT_ID"

# Confluent Cloud API key and secret — create at:
# https://confluent.cloud/settings/api-keys (cloud-level key, not cluster-scoped)
confluent_cloud_api_key    = "YOUR_CONFLUENT_CLOUD_API_KEY"
confluent_cloud_api_secret = "YOUR_CONFLUENT_CLOUD_API_SECRET"

# Identifier used to name the test schema inside Unity Catalog
test_cluster_id = "lkc-test-001"
