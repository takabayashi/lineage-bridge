# ============================================================================
# LineageBridge — Confluent Cloud Credentials
# ============================================================================
# Copy this file to .env and fill in your values.
# Only credentials go here. Environment/cluster selection happens in the UI.

# ── Confluent Cloud API key (required) ─────────────────────────────────
# Cloud-level API key with OrgAdmin or similar read permissions.
LINEAGE_BRIDGE_CONFLUENT_CLOUD_API_KEY=
LINEAGE_BRIDGE_CONFLUENT_CLOUD_API_SECRET=

# ── Optional: global service-scoped credentials ───────────────────────
# If not set, the cloud API key is used for all services.
# LINEAGE_BRIDGE_KAFKA_API_KEY=
# LINEAGE_BRIDGE_KAFKA_API_SECRET=
# LINEAGE_BRIDGE_SCHEMA_REGISTRY_ENDPOINT=https://psrc-xxxxx.region.cloud.confluent.cloud
# LINEAGE_BRIDGE_SCHEMA_REGISTRY_API_KEY=
# LINEAGE_BRIDGE_SCHEMA_REGISTRY_API_SECRET=
# LINEAGE_BRIDGE_KSQLDB_API_KEY=
# LINEAGE_BRIDGE_KSQLDB_API_SECRET=
# LINEAGE_BRIDGE_FLINK_API_KEY=
# LINEAGE_BRIDGE_FLINK_API_SECRET=
# LINEAGE_BRIDGE_TABLEFLOW_API_KEY=
# LINEAGE_BRIDGE_TABLEFLOW_API_SECRET=

# ── Optional: per-cluster API keys ────────────────────────────────────
# JSON map of cluster ID to credentials. Useful when each cluster has
# its own cluster-scoped API key. Falls back to KAFKA_API_KEY, then
# to the cloud API key.
# You can also enter per-cluster keys in the UI sidebar instead.
# LINEAGE_BRIDGE_CLUSTER_CREDENTIALS={"lkc-abc123":{"api_key":"...","api_secret":"..."},"lkc-def456":{"api_key":"...","api_secret":"..."}}

# ── Logging ────────────────────────────────────────────────────────────
LINEAGE_BRIDGE_LOG_LEVEL=INFO
