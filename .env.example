# ============================================================================
# LineageBridge Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# All variables are prefixed with LINEAGE_BRIDGE_.

# ── Confluent Cloud (required) ──────────────────────────────────────────────
# Cloud-level API key with org-admin or similar read permissions.
LINEAGE_BRIDGE_CONFLUENT_CLOUD_API_KEY=
LINEAGE_BRIDGE_CONFLUENT_CLOUD_API_SECRET=

# ── Environments to scan (required) ─────────────────────────────────────────
# Comma-separated list of Confluent Cloud environment IDs.
LINEAGE_BRIDGE_ENVIRONMENT_IDS=["env-abc123"]

# ── Kafka cluster filter (optional) ─────────────────────────────────────────
# If empty, all clusters in the listed environments will be scanned.
# LINEAGE_BRIDGE_KAFKA_CLUSTER_IDS=["lkc-abc123","lkc-def456"]

# ── Kafka cluster-scoped credentials (optional) ────────────────────────────
# Falls back to the cloud API key if not set.
# LINEAGE_BRIDGE_KAFKA_API_KEY=
# LINEAGE_BRIDGE_KAFKA_API_SECRET=

# ── Schema Registry credentials (optional) ─────────────────────────────────
# LINEAGE_BRIDGE_SCHEMA_REGISTRY_API_KEY=
# LINEAGE_BRIDGE_SCHEMA_REGISTRY_API_SECRET=

# ── ksqlDB credentials (optional) ──────────────────────────────────────────
# LINEAGE_BRIDGE_KSQLDB_API_KEY=
# LINEAGE_BRIDGE_KSQLDB_API_SECRET=

# ── Flink credentials (optional) ───────────────────────────────────────────
# LINEAGE_BRIDGE_FLINK_API_KEY=
# LINEAGE_BRIDGE_FLINK_API_SECRET=
# LINEAGE_BRIDGE_FLINK_REGION=us-east-1
# LINEAGE_BRIDGE_FLINK_CLOUD=aws

# ── Output ──────────────────────────────────────────────────────────────────
# Path where the extracted lineage graph JSON is saved.
LINEAGE_BRIDGE_EXTRACT_OUTPUT_PATH=./lineage_graph.json

# ── Logging ─────────────────────────────────────────────────────────────────
LINEAGE_BRIDGE_LOG_LEVEL=INFO
